{
  "name": "google-sheet-tampilan",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "node scripts/with-db-url.mjs migrate deploy",
    "db:migrate:dev": "node scripts/with-db-url.mjs migrate dev",
    "db:seed": "node scripts/with-db-url.mjs db seed",
    "db:push": "node scripts/with-db-url.mjs db push",
    "db:studio": "node scripts/with-db-url.mjs studio",
    "db:setup": "node scripts/db-reconcile.mjs && npm run db:migrate && npm run db:seed && node scripts/setup-reader-role.mjs",
    "db:reconcile": "node scripts/db-reconcile.mjs",
    "db:reader-role": "node scripts/setup-reader-role.mjs",
    "db:reset": "node scripts/with-db-url.mjs migrate reset",
    "db:reset-workspace": "node scripts/reset-workspace.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "16.2.9",
    "openai": "^6.43.0",
    "papaparse": "^5.5.3",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
