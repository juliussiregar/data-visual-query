# OpenAI API Key (wajib untuk fitur AI Chat)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Secret untuk enkripsi password koneksi DB & session (min 16 karakter)
APP_SECRET=ubah_dengan_string_acak_panjang

# Database aplikasi (users, koneksi sheet, layout)
# App di host: DB_HOST=localhost  DB_PORT=54327
# App di docker compose nanti: DB_HOST=db  DB_PORT=5432
DB_HOST=localhost
DB_PORT=54327
DB_NAME=sheetvision
DB_USER=sheetvision
DB_PASSWORD=ubah_password_kuat_disini
DB_READER_PASSWORD=sheetvision_reader

# Akun demo (setelah init DB): admin@sheetvision.local / changeme
