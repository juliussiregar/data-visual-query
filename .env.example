# Salin ke .env: cp .env.example .env

# OpenAI (opsional — untuk AI Chat)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Secret untuk enkripsi password koneksi DB & session (min 16 karakter, wajib)
APP_SECRET=ubah_dengan_string_acak_panjang_min_16_karakter

# Database aplikasi — wajib (Prisma)
# Untuk docker compose, DB_HOST/DB_PORT di-override oleh service app (db:5432).
DB_HOST=localhost
DB_PORT=54327
DB_NAME=sheetvision
DB_USER=sheetvision
DB_PASSWORD=ubah_password_kuat_disini
DB_READER_PASSWORD=sheetvision_reader

# Database analisis IoT (sumber data eksternal untuk dashboard)
# Jalankan: docker compose up -d analytics-db && npm run analytics:setup
ANALYTICS_DB_HOST=localhost
ANALYTICS_DB_PORT=54328
ANALYTICS_DB_NAME=iot_analytics
ANALYTICS_DB_USER=iot_admin
ANALYTICS_DB_PASSWORD=ubah_password_analytics_disini
ANALYTICS_DB_READER_USER=iot_reader
ANALYTICS_DB_READER_PASSWORD=iot_reader

# Database analisis retail MySQL (sumber data eksternal — uji koneksi MySQL)
# Jalankan: docker compose up -d mysql-analytics-db && npm run mysql:setup
MYSQL_ANALYTICS_DB_HOST=localhost
MYSQL_ANALYTICS_DB_PORT=33068
MYSQL_ANALYTICS_DB_NAME=retail_analytics
MYSQL_ANALYTICS_DB_USER=retail_admin
MYSQL_ANALYTICS_DB_PASSWORD=ubah_password_mysql_analytics_disini
MYSQL_ANALYTICS_DB_READER_USER=retail_reader
MYSQL_ANALYTICS_DB_READER_PASSWORD=retail_reader

# Prisma (opsional — otomatis dibangun dari DB_* jika kosong)
# DATABASE_URL=postgresql://sheetvision:password@localhost:54327/sheetvision

# Docker Compose
APP_PORT=3066
COMPOSE_PROJECT_NAME=data-visual-query
RUN_DB_MIGRATE=true
RUN_DB_SEED=false
RUN_DB_READER_ROLE=true

# Deploy dengan Docker:
#   cp .env.example .env   # lalu isi APP_SECRET & DB_PASSWORD
#   docker compose up -d --build
#
# Deploy pertama (seed akun admin):
#   RUN_DB_SEED=true docker compose up -d --build
#   # atau: docker compose run --rm -e RUN_DB_SEED=true app true
#
# Dev lokal tanpa container app:
#   docker compose up -d db analytics-db mysql-analytics-db
#   npm run db:setup
#   npm run analytics:setup
#   npm run mysql:setup
#
# Koneksi IoT DB di SheetVision (project → PostgreSQL):
#   Host localhost, Port 54328, DB iot_analytics, Schema public
#   User iot_reader / password ANALYTICS_DB_READER_PASSWORD
#   Tabel: sensor_readings, device_daily_summary, device_health_scores, devices, device_alerts
#
# Koneksi pendidikan (schema terpisah, DB & container sama):
#   Host localhost, Port 54328, DB iot_analytics, Schema education
#   User iot_reader — tabel: student_grades
#   Seed: npm run education:seed
#
# Koneksi retail MySQL di SheetVision (project → MySQL):
#   Host localhost, Port 33068, DB retail_analytics
#   User retail_reader / password MYSQL_ANALYTICS_DB_READER_PASSWORD
#   Tabel: orders, order_items, products, daily_sales_summary
#
# Akun seed: admin / admin123, superadmin / admin123
