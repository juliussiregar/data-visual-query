# OpenAI API Key (wajib untuk fitur AI Chat)
# Dapatkan di: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Model OpenAI (opsional, default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Upstash Redis — penyimpanan layout dashboard lintas perangkat (gratis)
# Daftar di https://upstash.com lalu salin REST URL & Token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
